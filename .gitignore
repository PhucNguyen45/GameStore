# =========================
# GameStore project ignore rules
# =========================

# ---------- .NET / ASP.NET ----------
**/bin/
**/obj/
**/out/
*.dll
*.exe
*.pdb
*.cache
*.deps.json
*.runtimeconfig.json
*.runtimeconfig.dev.json
*.AssemblyInfo.cs

# NuGet / package restore artifacts
*.nupkg
*.snupkg
packages/

# ---------- Frontend (React/Vite) ----------
node_modules/
dist/
build/
coverage/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------- Environment & secret config ----------
.env
.env.*
!.env.example
*.local
*.local.json

# Ignore all appsettings files that may contain secrets
**/appsettings.json
**/appsettings.*.json
!**/appsettings.Example.json
!**/appsettings.template.json

# Keep common local overrides ignored explicitly
appsettings.Development.json
appsettings.Local.json
appsettings.*.local.json
appsettings.Production.json
appsettings.*.production.json

# Optional: ignore local launch settings if they contain machine-specific ports/keys
**/Properties/launchSettings.json

# ---------- Database / storage ----------
database/
*.db
*.sqlite
*.sqlite3
*.mdf
*.ldf
*.bak

# ---------- Logs / temp files ----------
logs/
*.log
*.tmp
*.temp
*.pid
*.swp

# ---------- IDE / editor ----------
.vs/
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.rsuser
*.sln.docstates

# ---------- OS files ----------
.DS_Store
Thumbs.db

# ---------- Project dump / tooling ----------
project_dump.txt
.codegraph/

# ---------- Test results ----------
TestResults/
coverage/
*.trx
