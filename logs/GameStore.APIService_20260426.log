          INNER JOIN [Genres] AS [g1] ON [g0].[GenreId] = [g1].[Id]
      ) AS [s] ON [g2].[Id] = [s].[GameId]
      ORDER BY [g2].[TotalSales] DESC, [g2].[Id], [s].[Id]
